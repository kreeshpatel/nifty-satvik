ALLOWED_ORIGIN=https://your-app.vercel.app

# Zerodha Kite Connect (required for real-time data)
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Authentication
JWT_SECRET=generate_with_python_secrets_token_urlsafe_32
ENCRYPTION_KEY=generate_with_python_fernet_generate_key

# PostgreSQL (auto-set by Render when using render.yaml)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional — frontend origin used to build password-reset URLs
# (defaults to https://niftyquant.vercel.app if unset)
FRONTEND_URL=https://niftyquant.vercel.app

# Optional — when SMTP_HOST is unset, password-reset URLs are written to
# server logs and an admin can DM them manually. Leave blank until SMTP
# / Resend / SES is wired up.
SMTP_HOST=

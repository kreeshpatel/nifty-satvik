ALLOWED_ORIGIN=https://your-app.vercel.app

# Zerodha Kite Connect (required for real-time data + order placement)
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Zerodha auto-refresh (refresh_kite_session.py / cron-kite-refresh.yml). The owner Kite
# token expires 06:00 IST daily; these let the refresh log in programmatically via TOTP.
# Store as CI/host secrets, never commit real values.
ZERODHA_USER_ID=AB1234
ZERODHA_PASSWORD=your_zerodha_password
ZERODHA_TOTP_SECRET=your_32_char_base32_totp_secret

# SEBI static-IP forward proxy (tinyproxy on the whitelisted DigitalOcean droplet). Zerodha
# enforces a static Indian IP for login + REST, so any host that is NOT the droplet (Fly web
# dyno, GitHub-Actions runner, laptop) MUST route Kite traffic through this. Used by both
# routers/kite.py::_kite_proxies and refresh_kite_session.py. Unset = direct (droplet only).
KITE_PROXY_URL=http://user:pass@your.droplet.static.ip:8888

# Authentication
JWT_SECRET=generate_with_python_secrets_token_urlsafe_32
# Fernet key encrypting Kite tokens at rest — MUST be byte-identical on the Fly web app AND the
# droplet/CI running refresh_kite_session.py, or stored tokens become undecryptable.
ENCRYPTION_KEY=generate_with_python_fernet_generate_key

# PostgreSQL — Supabase session-pooler (:5432). Same DB the Fly app reads and the refresh writes.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional — frontend origin used to build password-reset URLs
# (defaults to https://niftyquant.vercel.app if unset)
FRONTEND_URL=https://niftyquant.vercel.app

# Optional — when SMTP_HOST is unset, password-reset URLs are written to
# server logs and an admin can DM them manually. Leave blank until SMTP
# / Resend / SES is wired up.
SMTP_HOST=

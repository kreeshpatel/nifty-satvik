!data/corporate_actions_demergers.csv
!data/nse_circulars/
!data/nse_circulars/*
!data/README.md
# results/ = run outputs. Only what the LH rebuild emits is whitelisted (live scan + paper book +
# kill state + cron health). cpcv_long.json stays ignored (it's a cloud artifact, not committed).
results/*
!results/README.md
!results/signals_today.json
!results/signals_history.json
!results/signal_analytics.json
!results/cron_health.json
!results/ohlcv_cache_lh.json
!results/portfolio_history.csv
!results/paper_portfolio.json
!results/paper_broker_state.json
!results/paper_trades.json
!results/paper_ledger_history.csv
!results/paper_equity_state.json
# PaperBook (Stage E) resume state — cash/positions/pending/trades/equity_curve. MUST persist
# across cron runs so the cloud cron resumes the book instead of resetting it every day.
!results/paper_state.json
# Kill-criteria + paper-equity runtime state must persist across cron runs (Stage E/F).
!results/kill_state.json
!results/kill_log.jsonl
# Weekly-swing forward-review scorecard (Oct-1 promote/kill machinery) — cron-refreshed, dashboard-read.
!results/weekly_review_scorecard.json
# The daily monitor's output MUST be committable — cron-bhanushali-monitor.yml `git add`s it, and
# without this whitelist the add silently no-ops (|| true) and the backend's intra-week overlay
# (live re-price + exit-tranche flags) never reaches production. Found dead 2026-07-18.
!results/weekly_monitor.json

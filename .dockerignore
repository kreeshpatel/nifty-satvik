# Keep the build context small.
#
# Anything listed here is NOT sent to Docker, NOT copied into the image.
# Source code lives in src/, tests/, config/, scripts/, diagnostics/ —
# everything else either rebuilds inside the container or gets mounted
# at runtime.

# VCS + CI metadata
.git
.github
.gitignore
.pre-commit-config.yaml

# Python caches + build artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.ruff_cache
.mypy_cache
htmlcov
.coverage
coverage.xml
build
dist
.venv
venv

# Node / frontend — has its own build pipeline
frontend
node_modules
dashboard/frontend

# Heavy data + models — developers mount these at runtime:
#   docker run -v $PWD/data:/home/app/niftyquant/data niftyquant ...
data
models
results
logs

# Keep the small diagnostic summaries out of the image — nothing in the
# container needs them, and they get regenerated by `make backtest`.
diagnostics/data/*.json

# Claude / agent tooling
.claude
.agents
claude-cookbooks
skills-lock.json

# OS cruft
.DS_Store
Thumbs.db
*.swp

# Docker itself
Dockerfile
.dockerignore

# nifty-satvik engine dirs — NOT needed by the FastAPI backend image (it serves the
# paper results via the GitHub API + its own dashboard/backend). Keep the image lean
# and don't ship research/test artifacts. config.py (root, needed by the backend
# bootstrap) and models/ (GitHub-fetched at runtime) are deliberately NOT excluded here.
tests
research
diagnostics
long_horizon
skills
.githooks
uv.lock
nifty_satvik.egg-info
BUILD_SPEC.md
